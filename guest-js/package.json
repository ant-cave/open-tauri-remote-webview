{
  "name": "open-tauri-remote-ui",
  "version": "0.14.0",
  "private": true,
  "description": "Remote browser UI access for Tauri v2 apps",
  "type": "module",
  "main": "./dist-js/api/index.js",
  "types": "./dist-js/api/index.d.ts",
  "exports": {
    "./api/core": {
      "types": "./dist-js/api/core.d.ts",
