{
  "name": "open-tauri-remote-webview",
  "version": "0.0.5-alpha.3",
  "private": false,
  "description": "Remote browser webview access for Tauri v2 apps",
  "type": "module",
  "main": "./dist-js/api/index.js",
  "types": "./dist-js/api/index.d.ts",
  "exports": {
    "./api/core": {
      "types": "./dist-js/api/core.d.ts",
      "import": "./dist-js/api/core.js"
    },
    "./api/event": {
      "types": "./dist-js/api/event.d.ts",
      "import": "./dist-js/api/event.js"
    },
    "./api/bridge": {
      "types": "./dist-js/api/bridge.d.ts",
      "import": "./dist-js/api/bridge.js"
    },
    "./bridge-init": {
      "types": "./dist-js/src/bridge-init.d.ts",
      "import": "./dist-js/src/bridge-init.js"
    },
    "./floating-badge": {
      "types": "./dist-js/src/floating-badge.d.ts",
      "import": "./dist-js/src/floating-badge.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist-js"
  ],
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
