{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "open-tauri-remote-ui": ["../../guest-js"],
      "open-tauri-remote-ui/*": ["../../guest-js/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
