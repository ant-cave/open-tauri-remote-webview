[package]
name = "open-tauri-remote-webview"
version = "0.0.1"
license = "MIT"
authors = ["DraviaVemal"]
description = "A Tauri plugin that exposes the application’s UI to a web browser, allowing full interaction while the native app continues running. This enables frontend debug, end-to-end UI testing using existing web-based testing tools without requiring modifications to the app itself."
edition = "2021"
rust-version = "1.77.2"
exclude = ["/examples", "/dist-js", "/guest-js", "/node_modules"]
links = "open-tauri-remote-webview"
repository = "https://github.com/ant-cave/open-tauri-remote-webview"

[dependencies]
tauri = { version = "2" }
serde = "1"
thiserror = "2"
tokio = { version = "1.47", features = ["full"] }
hyper = { version = "1", features = ["full"] }
hyper-util = "0.1"
hyper-tungstenite = "0.18"
serde_json = "1"
http-body-util = "0.1"
futures = "0.3"

[build-dependencies]
tauri-plugin = { version = "2.4.0", features = ["build"] }
